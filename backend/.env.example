# =============================================================
# backend/.env.example — Environment Variables Template
# 
# HOW TO USE:
#   1. Copy/rename this file to exactly:  .env
#   2. Fill in your actual values below
#   3. The .env file is in .gitignore — it will NEVER be committed
# =============================================================

# ── MQTT Broker ───────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SENSOR_DATA=smart_agriculture/sensor_data
MQTT_CLIENT_ID=fastapi_backend_01

# ── FastAPI Server ────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True
APP_TITLE=Smart Agriculture API
APP_VERSION=1.0.0

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=smart_agriculture
MONGO_COLLECTION_READINGS=sensor_readings
MONGO_COLLECTION_DAILY=daily_summaries

# ── Weather API ───────────────────────────────────────────────
# Get free key from: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key_here
WEATHER_CITY=Mahendranagar
