# MongoDB Atlas Connection (database: Agricult)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/Agricult?appName=Smart-Agriculture

# Frontend URL (for CORS whitelist)
FRONTEND_URL=http://localhost:3000

# Python ML Server URL (for CORS whitelist)
MLSERVER_URL=http://localhost:8000

# Server port
PORT=5000

# JWT token signing secret
TOKEN_SECRET_KEY=your_jwt_secret_here

# NextAuth shared secret (must match frontend AUTH_SECRET)
AUTH_SECRET=your_nextauth_secret_here
